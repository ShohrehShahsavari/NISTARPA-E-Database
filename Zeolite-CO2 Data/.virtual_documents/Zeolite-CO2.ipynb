# Function to search for DOI in all rows
def extract_doi(dataframe):
    for index, row in dataframe.iterrows():
        # Check if the row contains DOI information
        if 'DOI' in str(row.values):
            doi = (row.str.split(','))[0][1]
            return doi.strip('"')  # Remove quotes if present
    return None  # Return None if DOI not found

# Extract DOI
doi = extract_doi(df)
print(f"Extracted DOI: {doi}")


# Function to search for adsorbent in all rows
def extract_adsorbent(dataframe):
    for i, row in df.iterrows():
        # Check if the row contains adsorbent information
        if 'adsorbent' in str(row.values):
            adsorbent= (df.iloc[i+2]).str.split(',')[0][1]
            return adsorbent.strip('"') # Remove quotes if present
    return None # Return None if adsorbent not found
    
adsorbent= extract_adsorbent(df)
print(f'Extracted adsorbent: {adsorbent}')



