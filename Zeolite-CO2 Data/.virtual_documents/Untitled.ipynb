import csv
from io import StringIO

# Assuming the file content is stored as a string variable named 'file_content'
file_content = """[file content here]"""  # Replace with your actual content

# Split the content into lines
lines = file_content.strip().split('\n')

# Locate the start of the isotherm data table
start_index = None
for idx, line in enumerate(lines):
    if line.startswith('line,"pressure",'):
        start_index = idx
        break

if start_index is None:
    print("Isotherm data table not found.")
else:
    # Extract the relevant lines (header and data rows)
    data_lines = lines[start_index:]
    data_text = '\n'.join(data_lines)
    
    # Use StringIO to simulate a file-like object
    f = StringIO(data_text)
    
    # Parse using csv.DictReader
    reader = csv.DictReader(f)
    isotherm_data = list(reader)
    
    # Print the extracted data
    for row in isotherm_data:
        print(row)

# Optional: Convert to pandas DataFrame
import pandas as pd
df = pd.DataFrame(isotherm_data)
print(df)
