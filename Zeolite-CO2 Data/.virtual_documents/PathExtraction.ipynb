input_path = 'E:/Python Projects/shohreh/Shohreh_GitHub_Repository/NISTARPA-E Database/Zeolite-CO2 Data/documents_list.txt'
output_path = 'E:/Python Projects/shohreh/Shohreh_GitHub_Repository/NISTARPA-E Database/Zeolite-CO2 Data/output.txt'

with open(input_path, 'r') as f:
    lines = [line.strip() for line in f if line.strip()]  # Remove empty lines and whitespace

with open(output_path, 'w') as f:
    for i, line in enumerate(lines, 1):
        filename = line.split()[-1]  # Gets the last element (filename)
        # Write with comma except for last line
        f.write(f"'{filename}'{',' if i < len(lines) else ''}\n")


import re

input_path = 'E:/Python Projects/shohreh/Shohreh_GitHub_Repository/NISTARPA-E Database/Zeolite-CO2 Data/documents_list.txt'
output_path = 'E:/Python Projects/shohreh/Shohreh_GitHub_Repository/NISTARPA-E Database/Zeolite-CO2 Data/output.txt'

with open(input_path, 'r') as f_in, open(output_path, 'w') as f_out:
    for line in f_in:
        # Extract the last word (filename) using regex
        match = re.search(r'(\S+)$', line.strip())
        if match:
            filename = match.group(1)
            f_out.write(f"{filename}\n")

